[node name="VBoxContainer" type="VBoxContainer" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer" unique_id=870355293]
layout_mode = 2
size_flags_horizontal = 3

[node name="Label3" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=319313666]
layout_mode = 2
theme_override_font_sizes/font_size = 25
text = "OBJECTIVE"
horizontal_alignment = 1

[node name="Label2" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=414236967]
layout_mode = 2
text = "Each player attempts to beat the dealer (you) by getting a count as close to 21 as possible, without going over 21."
autowrap_mode = 2

[node name="Label4" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=1196100258]
layout_mode = 2
theme_override_font_sizes/font_size = 25
text = "CARD VALUES"
horizontal_alignment = 1

[node name="Label5" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=132394363]
layout_mode = 2
text = "It's up to each player whether an Ace is worth 1 or 11. Face cards (K, Q, J) are worth 10. All other cards are worth their face value."
autowrap_mode = 2

[node name="Label6" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=672522335]
layout_mode = 2
theme_override_font_sizes/font_size = 25
text = "BETTING & NATURALS"
horizontal_alignment = 1

[node name="Label7" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=519921699]
layout_mode = 2
text = "Before each round, all players place a bet against the dealer (you). If they win, they get that much from the casino's bank. If they lose, you get that bet as income. 

If a player gets exactly 21, it's called a natural, and they get 1.5x their bet. If you get a natural, the game immediately ends, and you get the bets of all players without one. "
autowrap_mode = 2

[node name="Label8" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=508643028]
layout_mode = 2
theme_override_font_sizes/font_size = 25
text = "THE PLAY"
horizontal_alignment = 1

[node name="Label9" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=1521678134]
layout_mode = 2
text = "The player to the left goes first, and decides to either \"Stand\" (not ask for another card) or \"Hit\" (Ask for another card to get closer to 21). Once a player Stands, they cannot Hit again afterwards. This continues in a circle for all players."
autowrap_mode = 2

[node name="Label10" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=425479618]
layout_mode = 2
theme_override_font_sizes/font_size = 25
text = "DEALER PLAY"
horizontal_alignment = 1

[node name="Label11" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=640419858]
layout_mode = 2
text = "After every player has gone, the dealer's face down card is flipped. If your total is under 17, the next card will be dealt to you, otherwise it continues to the next player. "
autowrap_mode = 2

[node name="Label12" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=200249254]
layout_mode = 2
theme_override_font_sizes/font_size = 25
text = "DOUBLING DOWN"
horizontal_alignment = 1

[node name="Label13" type="Label" parent="Options/MarginContainer/HBoxContainer/Panel2/MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=663760496]
layout_mode = 2
text = "As the rounds progress, players become more likely to double down. When the player's turn comes, they get one more card, placed face down, and double their bet."
autowrap_mode = 2

